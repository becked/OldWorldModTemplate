# Path to Old World game install. Used for C# mods (references game DLLs) and
# by upload scripts to detect the current game build for <modbuild> / mod.io
# metadata_blob, which the game uses to detect out-of-date mods.
# macOS (Steam): ~/Library/Application Support/Steam/steamapps/common/Old World
# Windows (Steam): C:\Program Files (x86)\Steam\steamapps\common\Old World
# Linux (Steam): ~/.steam/steam/steamapps/common/Old World
OLDWORLD_PATH=""

# Optional override for the game build string (e.g. "1.0.83082"). Required on
# Linux where automatic detection from OLDWORLD_PATH isn't implemented yet.
# OLDWORLD_BUILD=""

# Local deployment — path to your Old World mods folder
# macOS: ~/Library/Application Support/OldWorld/Mods
# Linux: ~/.local/share/OldWorld/Mods
# Windows: %APPDATA%\OldWorld\Mods
OLDWORLD_MODS_PATH=""

# Steam Workshop (optional)
# Install steamcmd: brew install steamcmd (macOS) or apt install steamcmd (Linux)
# STEAM_WORKSHOP_ID is set after your first upload — leave blank for new mods
STEAM_USERNAME=""
STEAM_WORKSHOP_ID=""

# mod.io (optional)
# Get your API URL and OAuth2 access token from https://mod.io/me/access
# MODIO_GAME_ID for Old World is 634
# MODIO_MOD_ID is auto-created on first upload — leave blank for new mods
MODIO_API_URL=""
MODIO_GAME_ID="634"
MODIO_MOD_ID=""
MODIO_ACCESS_TOKEN=""

# Comma-separated mod.io tags appended to the auto-derived Singleplayer/
# Multiplayer tags. Old World's taxonomy: Translation, Map, Other, MapScript,
# Nation, Tribe, Character, Family, GameInfo, Event, Scenario, AI, UI,
# Conversion. Tags surface your mod under the matching mod browser filters.
MODIO_TAGS=""
